<%- include('partials/header') %>

<!-- Search Donors Section -->
<section class="search-section py-5">
  <div class="container py-5">
    <div class="text-center mb-5">
      <i class="fas fa-search fa-4x text-danger mb-3"></i>
      <h2 class="display-5 fw-bold">Search Blood Donors</h2>
      <p class="lead">Find available blood donors in your area</p>
    </div>

    <!-- Flash Messages -->
    <% if (error && error.length > 0) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>
        <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <% if (success && success.length > 0) { %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>
        <%= success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <!-- Search Form -->
    <div class="search-form-card bg-white rounded shadow-lg p-4 mb-5">
      <form action="/search-donors" method="GET" class="row g-3">
        <div class="col-md-4">
          <label for="bloodGroup" class="form-label fw-bold">Blood Group</label>
          <select class="form-select form-select-lg" id="bloodGroup" name="bloodGroup">
            <option value="">All Blood Groups</option>
            <option value="A+" <%= searchParams.bloodGroup === 'A+' ? 'selected' : '' %>>A+</option>
            <option value="A-" <%= searchParams.bloodGroup === 'A-' ? 'selected' : '' %>>A-</option>
            <option value="B+" <%= searchParams.bloodGroup === 'B+' ? 'selected' : '' %>>B+</option>
            <option value="B-" <%= searchParams.bloodGroup === 'B-' ? 'selected' : '' %>>B-</option>
            <option value="AB+" <%= searchParams.bloodGroup === 'AB+' ? 'selected' : '' %>>AB+</option>
            <option value="AB-" <%= searchParams.bloodGroup === 'AB-' ? 'selected' : '' %>>AB-</option>
            <option value="O+" <%= searchParams.bloodGroup === 'O+' ? 'selected' : '' %>>O+</option>
            <option value="O-" <%= searchParams.bloodGroup === 'O-' ? 'selected' : '' %>>O-</option>
          </select>
        </div>
        <div class="col-md-4">
          <label for="city" class="form-label fw-bold">City</label>
          <input type="text" class="form-control form-control-lg" id="city" name="city" 
                 placeholder="Enter city name" value="<%= searchParams.city || '' %>">
        </div>
        <div class="col-md-4 d-flex align-items-end">
          <button type="submit" class="btn btn-danger btn-lg w-100 fw-bold">
            <i class="fas fa-search me-2"></i>Search Donors
          </button>
        </div>
      </form>
    </div>

    <!-- Search Results -->
    <div class="search-results">
      <% if (donors.length > 0) { %>
        <div class="row g-4">
          <% donors.forEach(function(donor) { %>
            <div class="col-lg-4 col-md-6">
              <div class="donor-card bg-white rounded shadow p-4 h-100">
                <div class="text-center mb-3">
                  <div class="donor-avatar bg-danger text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 80px; height: 80px;">
                    <i class="fas fa-user fa-2x"></i>
                  </div>
                  <h4 class="fw-bold mb-1"><%= donor.fullName %></h4>
                  <span class="badge bg-success fs-6"><%= donor.availabilityStatus %></span>
                </div>
                
                <hr>
                
                <div class="donor-info">
                  <div class="mb-2">
                    <i class="fas fa-tint text-danger me-2"></i>
                    <strong>Blood Group:</strong>
                    <span class="badge bg-danger fs-6"><%= donor.bloodGroup %></span>
                  </div>
                  <div class="mb-2">
                    <i class="fas fa-map-marker-alt text-danger me-2"></i>
                    <strong>City:</strong> <%= donor.city %>
                  </div>
                  <div class="mb-2">
                    <i class="fas fa-phone text-danger me-2"></i>
                    <strong>Contact:</strong> <%= donor.contactNumber %>
                  </div>
                  <div class="mb-2">
                    <i class="fas fa-venus-mars text-danger me-2"></i>
                    <strong>Gender:</strong> <%= donor.gender %>
                  </div>
                  <div class="mb-2">
                    <i class="fas fa-calendar text-danger me-2"></i>
                    <strong>Age:</strong> <%= donor.age %>
                  </div>
                  <% if (donor.lastDonationDate) { %>
                    <div class="mb-0">
                      <i class="fas fa-calendar-alt text-danger me-2"></i>
                      <strong>Last Donation:</strong> <%= donor.lastDonationDate.toLocaleDateString() %>
                    </div>
                  <% } else { %>
                    <div class="mb-0">
                      <i class="fas fa-calendar-alt text-danger me-2"></i>
                      <strong>Last Donation:</strong> Not donated yet
                    </div>
                  <% } %>
                </div>
                
                <!-- View Details Button -->
                <div class="mt-3">
                  <button type="button" class="btn btn-danger w-100 fw-bold" 
                          data-bs-toggle="modal" 
                          data-bs-target="#donorModal"
                          data-donor-name="<%= donor.fullName %>"
                          data-donor-blood="<%= donor.bloodGroup %>"
                          data-donor-city="<%= donor.city %>"
                          data-donor-phone="<%= donor.contactNumber %>"
                          data-donor-status="<%= donor.availabilityStatus %>"
                          data-donor-last-donation="<%= donor.lastDonationDate ? donor.lastDonationDate.toLocaleDateString() : 'Not donated yet' %>">
                    <i class="fas fa-info-circle me-2"></i>View Details
                  </button>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
        
        <div class="text-center mt-4">
          <p class="text-muted"><i class="fas fa-info-circle me-2"></i>Found <%= donors.length %> donor(s)</p>
        </div>
      <% } else { %>
        <div class="no-results text-center py-5">
          <i class="fas fa-search fa-5x text-muted mb-4"></i>
          <h3 class="fw-bold mb-3">No Donors Found</h3>
          <p class="lead text-muted">
            <% if (searchParams.bloodGroup || searchParams.city) { %>
              We couldn't find any donors matching your search criteria. Try different filters or check back later.
            <% } else { %>
              No donors are currently registered. Be the first to become a donor!
            <% } %>
          </p>
          <% if (!user) { %>
            <a href="/register" class="btn btn-danger btn-lg px-5 py-3 fw-bold mt-3">
              <i class="fas fa-user-plus me-2"></i>Register as Donor
            </a>
          <% } else { %>
            <a href="/become-donor" class="btn btn-danger btn-lg px-5 py-3 fw-bold mt-3">
              <i class="fas fa-tint me-2"></i>Become a Donor
            </a>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
</section>

<!-- Donor Details Modal -->
<div class="modal fade" id="donorModal" tabindex="-1" aria-labelledby="donorModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title fw-bold" id="donorModalLabel">
          <i class="fas fa-user-circle me-2"></i>Donor Details
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="text-center mb-4">
          <div class="donor-avatar bg-danger text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 100px; height: 100px;">
            <i class="fas fa-user fa-3x"></i>
          </div>
          <h4 class="fw-bold mb-2" id="modalDonorName">Donor Name</h4>
          <span class="badge bg-success fs-6" id="modalDonorStatus">Available</span>
        </div>
        
        <div class="donor-details-info">
          <div class="row mb-3">
            <div class="col-6">
              <div class="detail-item p-3 bg-light rounded">
                <i class="fas fa-tint text-danger fa-2x mb-2"></i>
                <p class="mb-0 text-muted small">Blood Group</p>
                <h5 class="fw-bold mb-0" id="modalDonorBlood">A+</h5>
              </div>
            </div>
            <div class="col-6">
              <div class="detail-item p-3 bg-light rounded">
                <i class="fas fa-map-marker-alt text-danger fa-2x mb-2"></i>
                <p class="mb-0 text-muted small">City</p>
                <h5 class="fw-bold mb-0" id="modalDonorCity">City Name</h5>
              </div>
            </div>
          </div>
          
          <div class="detail-item p-3 bg-light rounded mb-3">
            <i class="fas fa-phone text-danger fa-2x mb-2"></i>
            <p class="mb-0 text-muted small">Phone Number</p>
            <h5 class="fw-bold mb-0" id="modalDonorPhone">+1234567890</h5>
          </div>
          
          <div class="detail-item p-3 bg-light rounded mb-3">
            <i class="fas fa-calendar-alt text-danger fa-2x mb-2"></i>
            <p class="mb-0 text-muted small">Last Donation</p>
            <h5 class="fw-bold mb-0" id="modalDonorLastDonation">Not donated yet</h5>
          </div>
        </div>
        
        <!-- Action Buttons -->
        <div class="row g-2 mt-4">
          <div class="col-6">
            <a href="#" id="callNowBtn" class="btn btn-success w-100 fw-bold py-3">
              <i class="fas fa-phone-alt me-2"></i>Call Now
            </a>
          </div>
          <div class="col-6">
            <a href="#" id="whatsappBtn" class="btn btn-success w-100 fw-bold py-3" style="background-color: #25D366;">
              <i class="fab fa-whatsapp me-2"></i>WhatsApp
            </a>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<script>
// JavaScript to populate modal with donor data
document.addEventListener('DOMContentLoaded', function() {
  const donorModal = document.getElementById('donorModal');
  
  donorModal.addEventListener('show.bs.modal', function(event) {
    const button = event.relatedTarget;
    
    // Extract donor data from button attributes
    const donorName = button.getAttribute('data-donor-name');
    const donorBlood = button.getAttribute('data-donor-blood');
    const donorCity = button.getAttribute('data-donor-city');
    const donorPhone = button.getAttribute('data-donor-phone');
    const donorStatus = button.getAttribute('data-donor-status');
    const donorLastDonation = button.getAttribute('data-donor-last-donation');
    
    // Populate modal with donor data
    document.getElementById('modalDonorName').textContent = donorName;
    document.getElementById('modalDonorBlood').textContent = donorBlood;
    document.getElementById('modalDonorCity').textContent = donorCity;
    document.getElementById('modalDonorPhone').textContent = donorPhone;
    document.getElementById('modalDonorStatus').textContent = donorStatus;
    document.getElementById('modalDonorLastDonation').textContent = donorLastDonation;
    
    // Update status badge color based on availability
    const statusBadge = document.getElementById('modalDonorStatus');
    statusBadge.className = 'badge fs-6';
    if (donorStatus.toLowerCase() === 'available') {
      statusBadge.classList.add('bg-success');
    } else if (donorStatus.toLowerCase() === 'unavailable') {
      statusBadge.classList.add('bg-danger');
    } else {
      statusBadge.classList.add('bg-warning');
    }
    
    // Update Call Now button with tel: link
    const callNowBtn = document.getElementById('callNowBtn');
    callNowBtn.href = 'tel:' + donorPhone.replace(/[^0-9]/g, '');
    
    // Update WhatsApp button with wa.me link
    const whatsappBtn = document.getElementById('whatsappBtn');
    whatsappBtn.href = 'https://wa.me/' + donorPhone.replace(/[^0-9]/g, '');
  });
});
</script>

<%- include('partials/footer') %>
