<%- include('../partials/header') %>

<!-- Admin Users Management Section -->
<section class="admin-dashboard-section py-5">
  <div class="container py-5">
    <div class="row mb-4">
      <div class="col-12">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h1 class="display-5 fw-bold"><i class="fas fa-users-cog me-3 text-primary"></i>Manage Users</h1>
            <p class="lead text-muted">View and manage all registered users</p>
          </div>
          <a href="/admin/dashboard" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
          </a>
        </div>
      </div>
    </div>

    <!-- Flash Messages -->
    <% if (error && error.length > 0) { %>
      <div class="col-12 mb-4">
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <i class="fas fa-exclamation-circle me-2"></i>
          <%= error %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      </div>
    <% } %>

    <% if (success && success.length > 0) { %>
      <div class="col-12 mb-4">
        <div class="alert alert-success alert-dismissible fade show" role="alert">
          <i class="fas fa-check-circle me-2"></i>
          <%= success %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      </div>
    <% } %>

    <!-- Users Table -->
    <div class="row">
      <div class="col-12">
        <div class="table-card bg-white rounded shadow p-4">
          <% if (users.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-hover">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>City</th>
                    <th>Blood Group</th>
                    <th>Admin</th>
                    <th>Joined</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% users.forEach(function(user) { %>
                    <tr>
                      <td><%= user.fullName %></td>
                      <td><%= user.email %></td>
                      <td><%= user.phone %></td>
                      <td><%= user.city %></td>
                      <td><span class="badge bg-danger"><%= user.bloodGroup %></span></td>
                      <td>
                        <% if (user.isAdmin) { %>
                          <span class="badge bg-success">Yes</span>
                        <% } else { %>
                          <span class="badge bg-secondary">No</span>
                        <% } %>
                      </td>
                      <td><%= user.createdAt.toLocaleDateString() %></td>
                      <td>
                        <div class="btn-group" role="group">
                          <form action="/admin/users/<%= user._id %>/toggle-admin" method="POST" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-primary" title="Toggle Admin Status">
                              <i class="fas fa-user-shield"></i>
                            </button>
                          </form>
                          <form action="/admin/users/<%= user._id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this user? This will also delete their donor profile and blood requests.');">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete User">
                              <i class="fas fa-trash"></i>
                            </button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="text-center py-5">
              <i class="fas fa-users fa-5x text-muted mb-4"></i>
              <h4 class="fw-bold">No Users Found</h4>
              <p class="text-muted">There are no registered users in the system yet.</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
