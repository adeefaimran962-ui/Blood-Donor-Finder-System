<%- include('partials/header') %>

<!-- 404 Page Section -->
<section class="error-section py-5">
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-6 text-center">
        <div class="error-card">
          <i class="fas fa-exclamation-triangle fa-6x text-danger mb-4"></i>
          <h1 class="display-1 fw-bold text-danger mb-3">404</h1>
          <h2 class="display-5 fw-bold mb-3">Page Not Found</h2>
          <p class="lead text-muted mb-5">
            Oops! The page you're looking for doesn't exist or has been moved.
          </p>
          <a href="/" class="btn btn-danger btn-lg px-5 py-3 fw-bold">
            <i class="fas fa-home me-2"></i>Back to Home
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.error-section {
  background: linear-gradient(to bottom, #f8f9fa, #fff);
  min-height: calc(100vh - 76px);
  display: flex;
  align-items: center;
}

.error-card {
  padding: 3rem 1rem;
}

.error-card i {
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.1);
  }
}
</style>

<%- include('partials/footer') %>
