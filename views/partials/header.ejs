<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= typeof description !== 'undefined' ? description : 'Blood Donor Finder System - Connect blood donors with those in need' %>">
  <meta name="keywords" content="blood donor, blood donation, healthcare, save lives">
  <title><%= title %> - Blood Donor Finder</title>
  
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  
  <!-- Font Awesome Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
  
  <!-- Google Poppins Font -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<!-- Navigation -->
<nav class="navbar navbar-expand-lg navbar-dark bg-danger fixed-top">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">
      <i class="fas fa-heartbeat me-2"></i>Blood Donor Finder
    </a>
    
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item">
          <a class="nav-link active" href="/">Home</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/search-donors">Search Donors</a>
        </li>
        
        <% if (user) { %>
          <li class="nav-item">
            <a class="nav-link" href="/become-donor">Become Donor</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/blood-request">Blood Request</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/my-requests">My Requests</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/profile">Profile</a>
          </li>
          <li class="nav-item">
            <a class="nav-link btn btn-light text-danger fw-bold ms-2 px-4" href="/dashboard">
              <i class="fas fa-user me-2"></i>Dashboard
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link btn btn-outline-light fw-bold ms-2 px-4" href="/logout">
              <i class="fas fa-sign-out-alt me-2"></i>Logout
            </a>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link btn btn-light text-danger fw-bold ms-2 px-4" href="/login">
              <i class="fas fa-sign-in-alt me-2"></i>Login
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link btn btn-outline-light fw-bold ms-2 px-4" href="/register">
              <i class="fas fa-user-plus me-2"></i>Register
            </a>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
