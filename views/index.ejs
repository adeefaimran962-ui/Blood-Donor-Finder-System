<%- include('partials/header') %>

<!-- Hero Section -->
<section id="home" class="hero-section">
  <div class="container">
    <div class="row align-items-center min-vh-100">
      <div class="col-lg-6">
        <div class="hero-content">
          <h1 class="display-3 fw-bold text-white mb-4">
            Save Lives by <span class="text-warning">Donating Blood</span>
          </h1>
          <p class="lead text-white mb-4">
            Connect with blood donors in your area. Every donation can save up to 3 lives. Join our community of heroes today.
          </p>
          <div class="hero-buttons">
            <a href="#cta" class="btn btn-warning btn-lg px-5 py-3 fw-bold me-3">
              <i class="fas fa-heart me-2"></i>Donate Now
            </a>
            <a href="#about" class="btn btn-outline-light btn-lg px-5 py-3 fw-bold">
              Learn More
            </a>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="hero-image text-center">
          <i class="fas fa-tint fa-10x text-white opacity-75"></i>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- About Section -->
<section id="about" class="about-section py-5">
  <div class="container py-5">
    <div class="row align-items-center">
      <div class="col-lg-6 mb-4 mb-lg-0">
        <div class="about-image text-center">
          <i class="fas fa-hand-holding-heart fa-8x text-danger"></i>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="about-content">
          <h2 class="display-5 fw-bold mb-4">About Blood Donor Finder</h2>
          <p class="lead mb-4">
            Blood Donor Finder System is a platform designed to bridge the gap between blood donors and those in need of blood transfusions.
          </p>
          <p class="mb-4">
            Our mission is to make blood donation accessible and efficient. We connect donors with hospitals, blood banks, and patients who urgently need blood. Every second counts when it comes to saving lives.
          </p>
          <ul class="list-unstyled">
            <li class="mb-3">
              <i class="fas fa-check-circle text-danger me-2"></i>
              Easy donor registration
            </li>
            <li class="mb-3">
              <i class="fas fa-check-circle text-danger me-2"></i>
              Real-time blood availability
            </li>
            <li class="mb-3">
              <i class="fas fa-check-circle text-danger me-2"></i>
              Secure and reliable platform
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Why Donate Blood Section -->
<section id="why-donate" class="why-donate-section py-5 bg-light">
  <div class="container py-5">
    <div class="text-center mb-5">
      <h2 class="display-5 fw-bold mb-3">Why Donate Blood?</h2>
      <p class="lead">Your donation can make a life-saving difference</p>
    </div>
    
    <div class="row g-4">
      <div class="col-lg-4 col-md-6">
        <div class="why-card text-center p-4 bg-white rounded shadow h-100">
          <div class="icon-box mb-3">
            <i class="fas fa-heart fa-3x text-danger"></i>
          </div>
          <h4 class="fw-bold mb-3">Save Lives</h4>
          <p>One blood donation can save up to 3 lives. Your contribution matters more than you know.</p>
        </div>
      </div>
      
      <div class="col-lg-4 col-md-6">
        <div class="why-card text-center p-4 bg-white rounded shadow h-100">
          <div class="icon-box mb-3">
            <i class="fas fa-sync fa-3x text-danger"></i>
          </div>
          <h4 class="fw-bold mb-3">Replenish Blood</h4>
          <p>Your body replenishes the donated blood within 24-48 hours, making it a safe process.</p>
        </div>
      </div>
      
      <div class="col-lg-4 col-md-6">
        <div class="why-card text-center p-4 bg-white rounded shadow h-100">
          <div class="icon-box mb-3">
            <i class="fas fa-shield-alt fa-3x text-danger"></i>
          </div>
          <h4 class="fw-bold mb-3">Health Benefits</h4>
          <p>Regular blood donation can reduce the risk of heart disease and improve overall health.</p>
        </div>
      </div>
      
      <div class="col-lg-4 col-md-6">
        <div class="why-card text-center p-4 bg-white rounded shadow h-100">
          <div class="icon-box mb-3">
            <i class="fas fa-medkit fa-3x text-danger"></i>
          </div>
          <h4 class="fw-bold mb-3">Free Health Check</h4>
          <p>Each donation includes a mini health check-up to ensure you're in good condition.</p>
        </div>
      </div>
      
      <div class="col-lg-4 col-md-6">
        <div class="why-card text-center p-4 bg-white rounded shadow h-100">
          <div class="icon-box mb-3">
            <i class="fas fa-users fa-3x text-danger"></i>
          </div>
          <h4 class="fw-bold mb-3">Help Community</h4>
          <p>Your donation helps patients in your community, including cancer patients and accident victims.</p>
        </div>
      </div>
      
      <div class="col-lg-4 col-md-6">
        <div class="why-card text-center p-4 bg-white rounded shadow h-100">
          <div class="icon-box mb-3">
            <i class="fas fa-star fa-3x text-danger"></i>
          </div>
          <h4 class="fw-bold mb-3">Be a Hero</h4>
          <p>Become a hero in someone's life. Your selfless act can bring hope to families in need.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Features Section -->
<section id="features" class="features-section py-5">
  <div class="container py-5">
    <div class="text-center mb-5">
      <h2 class="display-5 fw-bold mb-3">Our Features</h2>
      <p class="lead">What makes Blood Donor Finder special</p>
    </div>
    
    <div class="row g-4">
      <div class="col-lg-3 col-md-6">
        <div class="feature-card text-center p-4 h-100">
          <div class="feature-icon mb-3">
            <i class="fas fa-search fa-3x text-danger"></i>
          </div>
          <h4 class="fw-bold mb-3">Easy Search</h4>
          <p>Find blood donors quickly by location, blood type, and availability.</p>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-6">
        <div class="feature-card text-center p-4 h-100">
          <div class="feature-icon mb-3">
            <i class="fas fa-bell fa-3x text-danger"></i>
          </div>
          <h4 class="fw-bold mb-3">Instant Alerts</h4>
          <p>Get notified when your blood type is needed in your area.</p>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-6">
        <div class="feature-card text-center p-4 h-100">
          <div class="feature-icon mb-3">
            <i class="fas fa-history fa-3x text-danger"></i>
          </div>
          <h4 class="fw-bold mb-3">Donation History</h4>
          <p>Track your donation history and see the impact you've made.</p>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-6">
        <div class="feature-card text-center p-4 h-100">
          <div class="feature-icon mb-3">
            <i class="fas fa-lock fa-3x text-danger"></i>
          </div>
          <h4 class="fw-bold mb-3">Secure Platform</h4>
          <p>Your data is protected with advanced security measures.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Statistics Section -->
<section id="statistics" class="statistics-section py-5 bg-danger">
  <div class="container py-5">
    <div class="text-center mb-5">
      <h2 class="display-5 fw-bold mb-3 text-white">Our Impact</h2>
      <p class="lead text-white">Numbers that speak for themselves</p>
    </div>
    
    <div class="row g-4">
      <div class="col-lg-3 col-md-6">
        <div class="stat-card text-center p-4 bg-white rounded shadow">
          <i class="fas fa-users fa-4x text-danger mb-3"></i>
          <h3 class="display-4 fw-bold text-danger">10,000+</h3>
          <p class="fw-bold">Registered Donors</p>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-6">
        <div class="stat-card text-center p-4 bg-white rounded shadow">
          <i class="fas fa-tint fa-4x text-danger mb-3"></i>
          <h3 class="display-4 fw-bold text-danger">25,000+</h3>
          <p class="fw-bold">Blood Donations</p>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-6">
        <div class="stat-card text-center p-4 bg-white rounded shadow">
          <i class="fas fa-heart fa-4x text-danger mb-3"></i>
          <h3 class="display-4 fw-bold text-danger">75,000+</h3>
          <p class="fw-bold">Lives Saved</p>
        </div>
      </div>
      
      <div class="col-lg-3 col-md-6">
        <div class="stat-card text-center p-4 bg-white rounded shadow">
          <i class="fas fa-hospital fa-4x text-danger mb-3"></i>
          <h3 class="display-4 fw-bold text-danger">500+</h3>
          <p class="fw-bold">Partner Hospitals</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Call To Action Section -->
<section id="cta" class="cta-section py-5">
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="cta-content text-center p-5 bg-danger rounded shadow">
          <h2 class="display-4 fw-bold text-white mb-4">Ready to Save a Life?</h2>
          <p class="lead text-white mb-4">
            Join thousands of heroes who have made a difference. Register as a blood donor today and help those in need.
          </p>
          <button class="btn btn-warning btn-lg px-5 py-3 fw-bold">
            <i class="fas fa-user-plus me-2"></i>Register as Donor
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
