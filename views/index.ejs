<!-- FAQ Section -->
<section id="faq" class="faq-section py-5 bg-light">
  <div class="container py-5">
    <div class="text-center mb-5">
      <h2 class="display-5 fw-bold mb-3">
        <i class="fas fa-question-circle text-danger me-3"></i>Frequently Asked Questions
      </h2>
      <p class="lead">Find answers to common questions about blood donation</p>
    </div>
    
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="accordion" id="faqAccordion">
          <!-- FAQ 1 -->
          <div class="accordion-item mb-3 rounded shadow">
            <h2 class="accordion-header">
              <button class="accordion-button fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq1" aria-expanded="true" aria-controls="faq1">
                <i class="fas fa-user-plus text-danger me-3"></i>Who can donate blood?
              </button>
            </h2>
            <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
              <div class="accordion-body">
                <p>Generally, you can donate blood if you:</p>
                <ul>
                  <li>Are between 18-65 years old</li>
                  <li>Weigh at least 50 kg (110 lbs)</li>
                  <li>Are in good health</li>
                  <li>Have not donated blood in the last 56 days</li>
                </ul>
                <p class="mb-0">Additional criteria may apply based on local regulations and your medical history.</p>
              </div>
            </div>
          </div>
          
          <!-- FAQ 2 -->
          <div class="accordion-item mb-3 rounded shadow">
            <h2 class="accordion-header">
              <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq2" aria-expanded="false" aria-controls="faq2">
                <i class="fas fa-calendar-alt text-danger me-3"></i>How often can I donate blood?
              </button>
            </h2>
            <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
              <div class="accordion-body">
                <p>You can donate whole blood every 56 days (8 weeks). For platelet donations, you can donate more frequently - every 7 days, up to 24 times a year. Plasma donations can be made every 28 days.</p>
                <p class="mb-0">Our system tracks your donation history and will notify you when you're eligible to donate again.</p>
              </div>
            </div>
          </div>
          
          <!-- FAQ 3 -->
          <div class="accordion-item mb-3 rounded shadow">
            <h2 class="accordion-header">
              <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq3" aria-expanded="false" aria-controls="faq3">
                <i class="fas fa-search text-danger me-3"></i>How do I search for a donor?
              </button>
            </h2>
            <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
              <div class="accordion-body">
                <p>Searching for a blood donor is simple:</p>
                <ol>
                  <li>Visit the "Search Donors" page from the navigation menu</li>
                  <li>Select the desired blood group from the dropdown</li>
                  <li>Enter the city name (optional)</li>
                  <li>Filter by availability status if needed</li>
                  <li>Click "Search Donors" to see matching results</li>
                </ol>
                <p class="mb-0">You can then view donor details and contact them directly via phone or WhatsApp.</p>
              </div>
            </div>
          </div>
          
          <!-- FAQ 4 -->
          <div class="accordion-item mb-3 rounded shadow">
            <h2 class="accordion-header">
              <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq4" aria-expanded="false" aria-controls="faq4">
                <i class="fas fa-shield-alt text-danger me-3"></i>Is my personal information secure?
              </button>
            </h2>
            <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
              <div class="accordion-body">
                <p>Absolutely! We take data security seriously:</p>
                <ul>
                  <li>All data is encrypted using industry-standard protocols</li>
                  <li>Your contact information is only shared with registered users who need blood</li>
                  <li>We comply with data protection regulations</li>
                  <li>You can control what information is visible in your profile</li>
                </ul>
                <p class="mb-0">We never sell your data to third parties and regularly update our security measures.</p>
              </div>
            </div>
          </div>
          
          <!-- FAQ 5 -->
          <div class="accordion-item mb-3 rounded shadow">
            <h2 class="accordion-header">
              <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq5" aria-expanded="false" aria-controls="faq5">
                <i class="fas fa-heart text-danger me-3"></i>How can I become a donor?
              </button>
            </h2>
            <div id="faq5" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
              <div class="accordion-body">
                <p>Becoming a donor is easy:</p>
                <ol>
                  <li>Register for an account on our platform</li>
                  <li>Complete your profile with accurate information</li>
                  <li>Fill out the donor registration form with your details</li>
                  <li>Set your availability status</li>
                  <li>You're now ready to save lives!</li>
                </ol>
                <p class="mb-0">You can update your profile and availability status anytime from your dashboard.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

