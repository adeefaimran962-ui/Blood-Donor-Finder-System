<%- include('partials/header') %>

<!-- Blood Request Section -->
<section class="auth-section py-5">
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="auth-card bg-white rounded shadow-lg p-5">
          <div class="text-center mb-5">
            <i class="fas fa-hand-holding-heart fa-4x text-danger mb-3"></i>
            <h2 class="display-5 fw-bold">Request Blood</h2>
            <p class="lead">Submit a blood request and find donors who can help</p>
          </div>

          <!-- Flash Messages -->
          <% if (error && error.length > 0) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
              <i class="fas fa-exclamation-circle me-2"></i>
              <%= error %>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          <% } %>

          <% if (success && success.length > 0) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
              <i class="fas fa-check-circle me-2"></i>
              <%= success %>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          <% } %>

          <!-- Blood Request Form -->
          <form action="/blood-request" method="POST" id="bloodRequestForm">
            <div class="row">
              <!-- Patient Name -->
              <div class="col-md-6 mb-4">
                <label for="patientName" class="form-label fw-bold">
                  <i class="fas fa-user me-2 text-danger"></i>Patient Name
                </label>
                <input type="text" 
                       class="form-control form-control-lg" 
                       id="patientName" 
                       name="patientName" 
                       placeholder="Enter patient name"
                       required
                       maxlength="50">
              </div>

              <!-- Blood Group Required -->
              <div class="col-md-6 mb-4">
                <label for="bloodGroupRequired" class="form-label fw-bold">
                  <i class="fas fa-tint me-2 text-danger"></i>Blood Group Required
                </label>
                <select class="form-select form-select-lg" 
                        id="bloodGroupRequired" 
                        name="bloodGroupRequired" 
                        required>
                  <option value="">Select blood group</option>
                  <option value="A+">A+</option>
                  <option value="A-">A-</option>
                  <option value="B+">B+</option>
                  <option value="B-">B-</option>
                  <option value="AB+">AB+</option>
                  <option value="AB-">AB-</option>
                  <option value="O+">O+</option>
                  <option value="O-">O-</option>
                </select>
              </div>

              <!-- Hospital Name -->
              <div class="col-md-6 mb-4">
                <label for="hospitalName" class="form-label fw-bold">
                  <i class="fas fa-hospital me-2 text-danger"></i>Hospital Name
                </label>
                <input type="text" 
                       class="form-control form-control-lg" 
                       id="hospitalName" 
                       name="hospitalName" 
                       placeholder="Enter hospital name"
                       required
                       maxlength="100">
              </div>

              <!-- City -->
              <div class="col-md-6 mb-4">
                <label for="city" class="form-label fw-bold">
                  <i class="fas fa-map-marker-alt me-2 text-danger"></i>City
                </label>
                <input type="text" 
                       class="form-control form-control-lg" 
                       id="city" 
                       name="city" 
                       placeholder="Enter city"
                       required
                       maxlength="50">
              </div>

              <!-- Required Date -->
              <div class="col-md-6 mb-4">
                <label for="requiredDate" class="form-label fw-bold">
                  <i class="fas fa-calendar-alt me-2 text-danger"></i>Required Date
                </label>
                <input type="date" 
                       class="form-control form-control-lg" 
                       id="requiredDate" 
                       name="requiredDate" 
                       required>
                <div class="form-text">Date must be today or in the future</div>
              </div>

              <!-- Contact Number -->
              <div class="col-md-6 mb-4">
                <label for="contactNumber" class="form-label fw-bold">
                  <i class="fas fa-phone me-2 text-danger"></i>Contact Number
                </label>
                <input type="tel" 
                       class="form-control form-control-lg" 
                       id="contactNumber" 
                       name="contactNumber" 
                       placeholder="Enter contact number"
                       required
                       pattern="[0-9]{10,15}"
                       title="Please enter a valid phone number (10-15 digits)">
              </div>

              <!-- Additional Notes -->
              <div class="col-12 mb-4">
                <label for="additionalNotes" class="form-label fw-bold">
                  <i class="fas fa-sticky-note me-2 text-danger"></i>Additional Notes
                </label>
                <textarea class="form-control form-control-lg" 
                          id="additionalNotes" 
                          name="additionalNotes" 
                          rows="4" 
                          placeholder="Any additional information (optional)"
                          maxlength="500"></textarea>
                <div class="form-text">Maximum 500 characters</div>
              </div>
            </div>

            <!-- Submit Button -->
            <div class="text-center mt-5">
              <button type="submit" class="btn btn-danger btn-lg px-5 py-3 fw-bold">
                <i class="fas fa-paper-plane me-2"></i>Submit Request
              </button>
            </div>
          </form>

          <!-- Back to Dashboard -->
          <div class="text-center mt-4">
            <a href="/dashboard" class="text-danger fw-bold text-decoration-none">
              <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>

<script>
// Set minimum date to today
const today = new Date().toISOString().split('T')[0];
document.getElementById('requiredDate').setAttribute('min', today);

// Client-side form validation
document.getElementById('bloodRequestForm').addEventListener('submit', function(e) {
  const contactNumber = document.getElementById('contactNumber').value;
  const requiredDate = document.getElementById('requiredDate').value;
  
  // Contact number validation
  const phoneRegex = /^[0-9]{10,15}$/;
  if (!phoneRegex.test(contactNumber)) {
    e.preventDefault();
    alert('Please enter a valid contact number (10-15 digits)');
    return false;
  }
  
  // Date validation
  const selectedDate = new Date(requiredDate);
  const currentDate = new Date();
  currentDate.setHours(0, 0, 0, 0);
  
  if (selectedDate < currentDate) {
    e.preventDefault();
    alert('Required date must be today or in the future');
    return false;
  }
});
</script>
